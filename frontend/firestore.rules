rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAgreementOwner(agreement) {
      return isAuthenticated() && agreement != null && (
        agreement.freelancerId == request.auth.uid ||
        agreement.creditorId == request.auth.uid ||
        agreement.debtorId == request.auth.uid ||
        agreement.clientId == request.auth.uid
      );

    }
    function hasValidClientToken() {
      return request.resource.data.clientAccessToken == resource.data.clientAccessToken
        && resource.data.clientAccessToken != null;
    }
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated() && request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    match /agreements/{agreementId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && (
        request.resource.data.freelancerId == request.auth.uid ||
        request.resource.data.creditorId == request.auth.uid ||
        request.resource.data.debtorId == request.auth.uid ||
        isAdmin()
      );


      allow update: if isAgreementOwner(resource.data) || isAdmin();
      allow delete: if isAdmin();
    }

    match /agreement_events/{eventId} {

      allow read: if isAuthenticated();

      allow create: if isAuthenticated() && (
        request.resource.data.actorId == request.auth.uid || isAdmin()
      );

      allow update, delete: if isAdmin();
    }

    match /deadline_extensions/{extensionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /amendments/{amendmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /charges/{chargeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /reputations/{reputationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
  }
}
