export type AgreementStatus = 
  | 'draft'
  | 'pending_client_confirmation'
  | 'confirmed'
  | 'contested'
  | 'in_adjustment'
  | 'closed'
  | 'rejected'
  | 'charge_open'
  | 'charge_contested'
  | 'deadline_extension_pending'
  | 'amendment_pending'
  | 'notice_sent'
  | 'in_dispute';

export type TimelineEventType = 
  | 'agreement_created'
  | 'invitation_sent'
  | 'client_confirmed'
  | 'client_contested'
  | 'amendment_adjustment_requested'
  | 'amendment_created'
  | 'amendment_accepted'
  | 'amendment_rejected'
  | 'deadline_extension_requested'
  | 'deadline_extension_accepted'
  | 'deadline_extension_counter_proposed'
  | 'deadline_extension_rejected'
  | 'charge_created'
  | 'charge_paid'
  | 'charge_contested'
  | 'notice_sent'
  | 'notice_responded'
  | 'case_closed'
  | 'agreement_updated'
  | 'revision_resent'
  | 'revision_limit_reached'
  | 'final_version_sent'
  | 'dispute_opened';

export interface Agreement {
  id: string;
  title: string;
  freelancerId: string;
  freelancerName: string;
  freelancerEmail: string;
  clientName: string;
  clientEmail: string;
  serviceType: string;
  description: string;
  value: number;
  deadline: Date | null;
  status: AgreementStatus;
  terms: string;
  hash: string;
  protocol: string;
  clientAccessToken: string;
  createdAt: Date | null;
  updatedAt: Date | null;
  timeline: TimelineEvent[];

  // Campos de revisão
  revisionMode?: boolean;
  revisionStatus?: string | null;
  originalAgreementId?: string | null;
  revisedAgreementId?: string | null;

  // ⭐ NOVOS CAMPOS PARA LIMITE DE 1 REVISÃO
  revisionCount?: number;
  revisionLimitReached?: boolean;
  finalVersion?: boolean;

  // Fallback para compatibilidade
  [key: string]: any;
}

export interface CreateAgreementDTO {
  title: string;
  freelancerId: string;
  freelancerName: string;
  freelancerEmail: string;
  clientName: string;
  clientEmail: string;
  serviceType: string;
  description: string;
  value: number;
  deadline: Date | null;
  terms?: string;
}

export interface TimelineEvent {
  id?: string;
  agreementId: string;
  type: TimelineEventType;
  actorType: 'freelancer' | 'client' | 'system';
  actorName: string;
  actorId?: string;
  title: string;
  description: string;
  metadata?: Record<string, any>;
  createdAt: Date;
}

export interface TimelineProps {
  events: TimelineEvent[];
  className?: string;
}

export interface TimelineEventItemProps {
  event: TimelineEvent;
  isLast?: boolean;
}

export interface DeadlineExtension {
  id: string;
  agreementId: string;
  requestedBy: 'freelancer' | 'client';
  requesterId: string;
  olddeadline: Date | string;
  proposeddeadline: Date | string;
  reason: string;
  status: 'pending' | 'accepted' | 'rejected';
  requestedAt: Date | string;
  respondedAt?: Date | string;
  responseNote?: string;
}

export interface Amendment {
  id: string;
  agreementId: string;
  createdBy: 'freelancer' | 'client';
  creatorId: string;
  changes: string;
  status: 'pending' | 'accepted' | 'rejected';
  createdAt: Date;
  acceptedAt?: Date;
}

export interface Charge {
  id: string;
  agreementId: string;
  amount: number;
  dueDate: Date;
  description: string;
  status: 'pending' | 'paid' | 'contested';
  createdBy: string;
  createdAt: Date;
  paidAt?: Date;
  paymentMethod?: string;
}

export interface Notice {
  id: string;
  agreementId: string;
  type: string;
  title: string;
  content: string;
  sentBy: 'freelancer' | 'client';
  senderId: string;
  sentAt: Date;
  readAt?: Date;
  response?: string;
  respondedAt?: Date;
}

export interface Reputation {
  id: string;
  userId: string;
  agreementId?: string;
  score: number;
  comment?: string;
  createdBy: string;
  createdAt: Date;
  updatedAt: Date;
}

export type FreelancerAction = 
  | 'edit_agreement'
  | 'send_invitation'
  | 'view_history'
  | 'request_deadline_extension'
  | 'create_amendment'
  | 'create_charge'
  | 'send_notice'
  | 'close_case';

export type ClientAction = 
  | 'confirm_agreement'
  | 'contest_agreement'
  | 'not_recognize'
  | 'view_history'
  | 'accept_deadline_extension'
  | 'counter_propose_deadline'
  | 'reject_deadline_extension'
  | 'accept_amendment'
  | 'request_amendment_adjustment'
  | 'reject_amendment'
  | 'report_payment'
  | 'contest_charge'
  | 'respond_notice';

export interface StatePermissions {
  freelancer: FreelancerAction[];
  client: ClientAction[];
  blocked: string[];
  statusLabel: string;
  statusColor: string;
  description: string;
}