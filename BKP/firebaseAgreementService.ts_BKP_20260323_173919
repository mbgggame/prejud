      ? `${baseUrl}/p/${protocolOrId}?t=${clientAccessToken}`
      : `${baseUrl}/p/${protocolOrId}`;
  }

  // ==================== ENVIO DE EMAIL ====================

  export async function sendAgreementInvitationEmail(
    agreementId: string,
    clientEmail: string,
    clientName: string,
    freelancerName: string,
    agreementTitle: string,
    clientAccessToken: string,
    confirmationLink?: string
  ): Promise<{ success: boolean; skipped?: boolean; error?: string; status?: number }> {
    try {
      const link =
        confirmationLink || buildPublicAgreementLink(agreementId, clientAccessToken);

      const response = await fetch('/api/send-agreement-invitation', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          clientEmail,
          clientName,
          freelancerName,
          agreementTitle,
          confirmationLink: link
        })
      });

      let errorMessage = 'Falha ao enviar email de convite.';
      let responseBody: unknown = null;

      const contentType = response.headers.get('content-type') || '';

      if (contentType.includes('application/json')) {
        responseBody = await response.json().catch(() => null);
      } else {
        const textBody = await response.text().catch(() => '');
        responseBody = textBody || null;
      }

      if (!response.ok) {
        if (
          responseBody &&
          typeof responseBody === 'object' &&
          'error' in responseBody &&
          typeof (responseBody as { error?: unknown }).error === 'string'
        ) {
          errorMessage = (responseBody as { error: string }).error;
        } else if (typeof responseBody === 'string' && responseBody.trim()) {
          errorMessage = responseBody.trim().slice(0, 300);
        }

        console.error('Erro ao enviar email de convite:', {
          status: response.status,
          statusText: response.statusText,
          body: responseBody
        });

        return {
          success: false,
          error: errorMessage,
          status: response.status
        };
      }

      return { success: true, status: response.status };
    } catch (error) {
      console.error('Falha ao enviar email de convite:', error);
      return {
        success: false,
        error: error instanceof Error ? error.message : 'Unknown error'
      };
    }
  }

  // ==================== CREATE AGREEMENT ====================

  export async function createAgreement(
    data: Omit<Agreement, 'id' | 'createdAt' | 'updatedAt' | 'timeline' | 'protocol'>
  ): Promise<Agreement> {
    const agreementRef = doc(collection(db, COLLECTIONS.AGREEMENTS));
    const eventRef = doc(collection(db, COLLECTIONS.AGREEMENT_EVENTS));
    const timestamp = serverTimestamp();
    const protocol = `PRJ-${Date.now()}`;
    const now = new Date();
    const nowIso = now.toISOString();
    const clientAccessToken =
      typeof crypto !== 'undefined' && crypto.randomUUID
        ? crypto.randomUUID()
        : Math.random().toString(36).substring(2) + Date.now().toString(36);

    const currentUserId = auth.currentUser?.uid || '';
    const currentUserEmail = auth.currentUser?.email || '';

    const hash = generateAgreementHash({
      title: data.title,
      freelancerId: currentUserId,
      clientEmail: data.clientEmail,
      value: data.value,
      deadline: data.deadline,
      protocol,
      createdAt: nowIso
    });

    const agreementData = {
      ...data,
      freelancerId: currentUserId,
      freelancerEmail: data.freelancerEmail || currentUserEmail,
      protocol,
      clientAccessToken,
      hash,
      status: 'pending_client_confirmation',
      revisionCount: 0,
      maxRevisions: MAX_REVISIONS,
      timeline: [],
      createdAt: timestamp,
      updatedAt: timestamp
    };

    const eventData = {
      agreementId: agreementRef.id,
      type: 'agreement_created',
      actorType: 'freelancer',
      actorName: data.freelancerName,
      actorId: currentUserId,
      title: 'Acordo criado',
      description: `Acordo "${data.title}" foi formalizado`,
      metadata: {
        protocol,
        serviceType: data.serviceType
      },
      createdAt: timestamp
    };

    const batch = writeBatch(db);
    batch.set(agreementRef, agreementData);
    batch.set(eventRef, eventData);
    await batch.commit();

    const confirmationLink = buildPublicAgreementLink(agreementRef.id, clientAccessToken);

    const notificationPromises: Promise<any>[] = [
      sendAgreementInvitationEmail(
        agreementRef.id,
        data.clientEmail,
        data.clientName,
        data.freelancerName,
        data.title,
        clientAccessToken,
        confirmationLink
      )
    ];

    if ((data as any).clientPhone) {
      notificationPromises.push(
        sendAgreementInvitationWhatsApp(
          (data as any).clientPhone,
          data.clientName,
          data.freelancerName,
          data.title,
          confirmationLink
        )
      );
    }

    const settled = await Promise.allSettled(notificationPromises);

    settled.forEach((result, index) => {
      if (result.status === 'rejected') {
        console.error(`❌ Falha ao enviar notificação ${index + 1}:`, result.reason);
        return;
      }

      if (result.value && result.value.success === false) {
        console.error(`❌ Notificação ${index + 1} retornou falha controlada:`, result.value);
      }
    });

    return {
      id: agreementRef.id,
      ...data,
      freelancerId: currentUserId,
      freelancerEmail: data.freelancerEmail || currentUserEmail,
      protocol,
      clientAccessToken,
      hash,
      status: 'pending_client_confirmation',
      revisionCount: 0,
      maxRevisions: MAX_REVISIONS,
      timeline: [],
      createdAt: now,
      updatedAt: now,
      terms: data.terms || ''
    } as unknown as Agreement;
  }

  // ==================== REENVIO APÓS REVISÃO (CORRIGIDO) ====================

  export async function resendAgreementAfterRevision(
    agreementId: string,
    updatedData: Partial<Agreement>,
    userId: string
  ): Promise<void> {
    const agreementRef = doc(db, COLLECTIONS.AGREEMENTS, agreementId);
    const timestamp = serverTimestamp();

    const agreementSnap = await getDoc(agreementRef);
    if (!agreementSnap.exists()) {
      throw new Error('Acordo não encontrado.');
    }

    const agreementData = agreementSnap.data();

    if (agreementData.freelancerId !== userId) {
      throw new Error('Sem permissão para editar este acordo.');
    }

    if (agreementData.status !== 'in_adjustment') {
      throw new Error('Acordo não está em ajuste.');
    }

    const updatePayload = {
      ...(updatedData.title !== undefined && { title: updatedData.title }),
      ...(updatedData.value !== undefined && { value: updatedData.value }),
      ...(updatedData.serviceType !== undefined && { serviceType: updatedData.serviceType }),
      ...(updatedData.description !== undefined && { description: updatedData.description }),
      ...(updatedData.terms !== undefined && { terms: updatedData.terms }),
      ...(updatedData.deadline !== undefined && { deadline: updatedData.deadline }),
      ...(updatedData.paymentTerms !== undefined && { paymentTerms: updatedData.paymentTerms }),

      status: 'pending_client_confirmation',
      updatedAt: timestamp,

      revisionRequestedAt: null,
      lastRevisionMessage: null,

      protocol: agreementData.protocol,
      clientAccessToken: agreementData.clientAccessToken,
      hash: agreementData.hash,
      freelancerId: agreementData.freelancerId,
      freelancerEmail: agreementData.freelancerEmail,
      clientEmail: agreementData.clientEmail,
      createdAt: agreementData.createdAt,
      revisionCount: agreementData.revisionCount || 0,
      maxRevisions: agreementData.maxRevisions || MAX_REVISIONS
    };

    const eventData = {
      agreementId,
      type: 'resent_after_revision',
      actorType: 'freelancer',
      actorName: agreementData.freelancerName || 'Freelancer',
      actorId: userId,
      title: 'Acordo reenviado',
      description: 'Freelancer ajustou e reenviou o acordo para nova confirmação do cliente.',
      metadata: {
        previousStatus: agreementData.status,
        newStatus: 'pending_client_confirmation',
        revisionCount: agreementData.revisionCount || 0
      },
      createdAt: timestamp
    };

    const batch = writeBatch(db);
    batch.update(agreementRef, updatePayload);

    const eventRef = doc(collection(db, COLLECTIONS.AGREEMENT_EVENTS));
    batch.set(eventRef, eventData);

    await batch.commit();

    try {
      const agreementLink = buildPublicAgreementLink(
        agreementData.protocol || agreementId,
        agreementData.clientAccessToken
      );

      await fetch('/api/send-agreement-response', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'final_version',
          clientEmail: agreementData.clientEmail,
          clientName: agreementData.clientName,
          freelancerEmail: agreementData.freelancerEmail,
          freelancerName: agreementData.freelancerName,
          agreementTitle: updatedData.title || agreementData.title,
          agreementLink
        })
      });
    } catch (emailError) {
      console.error('⚠️ Acordo reenviado, mas houve falha ao enviar email ao cliente:', emailError);
    }
  }

  // ==================== FECHAR ACORDO (NOVO) ====================

  export async function closeAgreement(
    agreementId: string,
    userId: string,
    reason?: string
  ): Promise<void> {
    const agreementRef = doc(db, COLLECTIONS.AGREEMENTS, agreementId);
    const timestamp = serverTimestamp();

    const agreementSnap = await getDoc(agreementRef);
    if (!agreementSnap.exists()) {
      throw new Error('Acordo não encontrado.');
    }

    const agreementData = agreementSnap.data();

    if (agreementData.freelancerId !== userId) {
      throw new Error('Sem permissão para fechar este acordo.');
    }

    const batch = writeBatch(db);

    batch.update(agreementRef, {
      status: 'closed',
      updatedAt: timestamp,
      closedAt: timestamp,
      closeReason: reason || null
    });

    const eventRef = doc(collection(db, COLLECTIONS.AGREEMENT_EVENTS));
    batch.set(eventRef, {
      agreementId,
      type: 'closed',
      actorType: 'freelancer',
      actorName: agreementData.freelancerName || 'Freelancer',
      actorId: userId,
      title: 'Acordo encerrado',
      description: reason || 'Acordo foi encerrado pelo freelancer.',
      metadata: {
        previousStatus: agreementData.status,
        reason
      },
      createdAt: timestamp
    });

    await batch.commit();
  }

  // ==================== RECUSAR REVISÃO E ENCERRAR (NOVO) ====================

  export async function rejectRevisionAndClose(
    agreementId: string,
    userId: string,
    reason?: string
  ): Promise<void> {
    const agreementRef = doc(db, COLLECTIONS.AGREEMENTS, agreementId);
    const timestamp = serverTimestamp();

    const agreementSnap = await getDoc(agreementRef);
    if (!agreementSnap.exists()) {
      throw new Error('Acordo não encontrado.');
    }

    const agreementData = agreementSnap.data();

    if (agreementData.freelancerId !== userId) {
      throw new Error('Sem permissão para este acordo.');
    }

    if (agreementData.status !== 'in_adjustment') {
      throw new Error('Acordo não está em revisão.');
    }

    const batch = writeBatch(db);

    batch.update(agreementRef, {
      status: 'closed',
      updatedAt: timestamp,
      closedAt: timestamp,
      closeReason: reason || 'Freelancer recusou a revisão solicitada pelo cliente',
      revisionRejected: true
    });

    const eventRef = doc(collection(db, COLLECTIONS.AGREEMENT_EVENTS));
    batch.set(eventRef, {
      agreementId,
      type: 'revision_rejected',
      actorType: 'freelancer',
      actorName: agreementData.freelancerName || 'Freelancer',
      actorId: userId,
      title: 'Revisão recusada - Acordo encerrado',
      description: reason || 'Freelancer recusou a revisão solicitada e encerrou o acordo.',
      metadata: {
        previousStatus: agreementData.status,
        clientRevisionMessage: agreementData.lastRevisionMessage
      },
      createdAt: timestamp
    });

    await batch.commit();

    try {
      const agreementLink = buildPublicAgreementLink(
        agreementData.protocol || agreementId,
        agreementData.clientAccessToken
      );

      await fetch('/api/send-agreement-response', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'final_version',
          clientEmail: agreementData.clientEmail,
          clientName: agreementData.clientName,
          freelancerEmail: agreementData.freelancerEmail,
          freelancerName: agreementData.freelancerName,
          agreementTitle: agreementData.title,
          agreementLink
        })
      });
    } catch (emailError) {
      console.error('Erro ao notificar cliente:', emailError);
    }
  }

